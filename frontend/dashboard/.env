# API Gateway WebSocket URL.
# Example: wss://abc123.execute-api.us-east-1.amazonaws.com/dev
VITE_WS_URL="wss://lnn7jf2ypa.execute-api.us-east-1.amazonaws.com/dev/"

# Comma-separated topics subscribed at startup.
VITE_DEFAULT_TOPICS=global

# Heartbeat prevents API Gateway idle timeout and lets the backend refresh the DynamoDB TTL.
# Your $default Lambda should accept this action and update the connection TTL.
VITE_HEARTBEAT_ACTION=heartbeat
VITE_HEARTBEAT_INTERVAL_MS=240000



# Optional: show realistic fallback data before the first WebSocket update.
VITE_ENABLE_DEMO_DATA=false
